<IfModule mod_rewrite.c>
    Options -MultiViews
    RewriteEngine On
    
    # Si el archivo existe (imágenes, css), cárgalo directo
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f
    
    # Si no, pásalo a index.php como variable 'url'
    RewriteRule ^(.+)$ index.php?url=$1 [QSA,L]
</IfModule>